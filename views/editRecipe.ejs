<form action="UpdateRecipe" 
      id="editRecipeForm" 
      method="post" 
      name="editRecipeForm"> 
 <input id="recipeName" 
        name="recipeName" 
        type="hidden" 
        value="<%= recipeData.Recipe.Title[0].$.name %>">   

 <div class="recipe-line">
  <span class="field-header">
   Cuisine:
  </span>
  <span class="field-value">
   <select id="cuisines" name="cuisine">
    <%  
     Object.keys(enums.CuisineTypes).forEach(function(key, index) { 
    %>
     <% var s = (key == recipeData.Recipe.Title[0].$.cuisine ? "selected" : " "); %>
     <option <%=s%> value="<%=key %>"><%=this[key]%></option>
    <% 
     }, enums.CuisineTypes); 
    %>
   </select>
  </span>
 </div>
 
 <div class="recipe-line">
  <span class="field-header">
   Course:
  </span>
  <span class="field-value">
   <select id="categories" name="category">
    <%  
     Object.keys(enums.CategoryTypes).forEach(function(key, index) { 
    %>
     <% var s = (key == recipeData.Recipe.Title[0].$.category ? "selected" : " "); %>
     <option <%=s%> value="<%=key %>"><%=this[key]%></option>
    <% 
     }, enums.CategoryTypes); 
    %>
   </select>    
  </span>
 </div>
 
 <div class="recipe-line">
  <span class="field-header">
   Yield:
  </span>
  <span class="field-value">
   <input data-validation="<%= (validationRules.GetValidationRule('yield')).GetFieldTypeId(); %>" 
          id="yield" 
          max="<%= (validationRules.GetValidationRule('yield')).GetMaxValue(); %>" 
          maxLength="<%= (validationRules.GetValidationRule('yield')).GetMaxLength(); %>"
          min="<%= (validationRules.GetValidationRule('yield')).GetMinValue(); %>" 
          minLength="<%= (validationRules.GetValidationRule('yield')).GetMinLength(); %>"
          name="yield"
          <%= (validationRules.GetValidationRule('yield')).IsRequired(); %>          
          type="number"
          value="<%=recipeData.Recipe.Title[0].Yield[0].$.amount %>">
   <select id="yieldUnit" name="yieldUnit">
    <%  
     Object.keys(enums.UnitTypes).forEach(function(key, index) { 
    %>
     <% var s = (key == recipeData.Recipe.Title[0].Yield[0].$.units ? "selected" : " "); %>
     <option <%=s%> value="<%=key %>"><%=this[key]%></option>
    <% 
     }, enums.UnitTypes); 
    %>
   </select>
  </span>
 </div> 
 
 <div class="recipe-line">
  <span class="field-header">
   Serving Size:
  </span>
  <span class="field-value">
   <input data-validation="vNumeric" 
          id="servings" 
          max="999" 
          min="1" 
          name="servings" 
          type="number" 
          value="<%=recipeData.Recipe.Nutrition[0].$.servings %>">
   <select id="servingsUnit" name="servingsUnit">
    <%  
     Object.keys(enums.ServingSizeTypes).forEach(function(key, index) { 
    %>
     <% var s = (key == recipeData.Recipe.Nutrition[0].$.servingsUnit ? "selected" : " "); %>
     <option <%=s%> value="<%=key %>"><%=this[key]%></option>
    <% 
     }, enums.ServingSizeTypes); 
    %>
   </select>
  </span>
 </div>  
 
 <div class="recipe-line">
  <span class="field-header">
   Preparation Time:
  </span>
  <span class="field-value">
   <input data-validation="<%= (validationRules.GetValidationRule('prepTime')).GetFieldTypeId(); %>" 
          id="prepTime" 
          max="<%= (validationRules.GetValidationRule('prepTime')).GetMaxValue(); %>" 
          maxLength="<%= (validationRules.GetValidationRule('prepTime')).GetMaxLength(); %>"
          min="<%= (validationRules.GetValidationRule('prepTime')).GetMinValue(); %>" 
          minLength="<%= (validationRules.GetValidationRule('prepTime')).GetMinLength(); %>"
          name="prepTime"
          <%= (validationRules.GetValidationRule('prepTime')).IsRequired(); %>          
          type="number"
          value="<%=recipeData.Recipe.Title[0].Times[0].$.prep %>"> minutes
  </span>
 </div> 
 
 <div class="recipe-line">
  <span class="field-header">
   Cook Time:
  </span>
  <span class="field-value">
   <input data-validation="<%= (validationRules.GetValidationRule('cookTime')).GetFieldTypeId(); %>" 
          id="cookTime" 
          max="<%= (validationRules.GetValidationRule('cookTime')).GetMaxValue(); %>" 
          maxLength="<%= (validationRules.GetValidationRule('cookTime')).GetMaxLength(); %>"
          min="<%= (validationRules.GetValidationRule('cookTime')).GetMinValue(); %>" 
          minLength="<%= (validationRules.GetValidationRule('cookTime')).GetMinLength(); %>"
          name="cookTime"
          <%= (validationRules.GetValidationRule('cookTime')).IsRequired(); %>          
          type="number"
          value="<%=recipeData.Recipe.Title[0].Times[0].$.cook %>"> minutes
  </span>
 </div>  
 
 <div class="recipe-line">
  <span class="field-header">
   Calories:
  </span>
  <span class="field-value">
   <input data-validation="<%= (validationRules.GetValidationRule('calories')).GetFieldTypeId(); %>" 
          id="calories" 
          max="<%= (validationRules.GetValidationRule('calories')).GetMaxValue(); %>" 
          maxLength="<%= (validationRules.GetValidationRule('calories')).GetMaxLength(); %>"
          min="<%= (validationRules.GetValidationRule('calories')).GetMinValue(); %>" 
          minLength="<%= (validationRules.GetValidationRule('calories')).GetMinLength(); %>"
          name="calories"
          <%= (validationRules.GetValidationRule('calories')).IsRequired(); %>          
          type="number"
          value="<%=recipeData.Recipe.Nutrition[0].$.calories %>"> 
  </span>
 </div>  
 
 <div class="recipe-line">
  <span class="field-header">
   Saturated Fat:
  </span>
  <span class="field-value">
   <input data-validation="<%= (validationRules.GetValidationRule('saturatedFat')).GetFieldTypeId(); %>" 
          id="saturatedFat" 
          max="<%= (validationRules.GetValidationRule('saturatedFat')).GetMaxValue(); %>" 
          maxLength="<%= (validationRules.GetValidationRule('saturatedFat')).GetMaxLength(); %>"
          min="<%= (validationRules.GetValidationRule('saturatedFat')).GetMinValue(); %>" 
          minLength="<%= (validationRules.GetValidationRule('saturatedFat')).GetMinLength(); %>"
          name="saturatedFat"
          <%= (validationRules.GetValidationRule('saturatedFat')).IsRequired(); %>          
          type="number"
          value="<%=recipeData.Recipe.Nutrition[0].$.saturatedFat %>"> g
  </span>
 </div> 
 
 <div class="recipe-line">
  <span class="field-header">
   Cholesterol:
  </span>
  <span class="field-value">
   <input data-validation="<%= (validationRules.GetValidationRule('cholesterol')).GetFieldTypeId(); %>" 
          id="cholesterol" 
          max="<%= (validationRules.GetValidationRule('cholesterol')).GetMaxValue(); %>" 
          maxLength="<%= (validationRules.GetValidationRule('cholesterol')).GetMaxLength(); %>"
          min="<%= (validationRules.GetValidationRule('cholesterol')).GetMinValue(); %>" 
          minLength="<%= (validationRules.GetValidationRule('cholesterol')).GetMinLength(); %>"
          name="cholesterol"
          <%= (validationRules.GetValidationRule('cholesterol')).IsRequired(); %>          
          value="<%=recipeData.Recipe.Nutrition[0].$.cholesterol %>"> g
  </span>
 </div> 
 
 <div class="recipe-line">
  <span class="field-header">
   Fat:
  </span>
  <span class="field-value">
   <input data-validation="<%= (validationRules.GetValidationRule('fat')).GetFieldTypeId(); %>" 
          id="fat" 
          max="<%= (validationRules.GetValidationRule('fat')).GetMaxValue(); %>" 
          maxLength="<%= (validationRules.GetValidationRule('fat')).GetMaxLength(); %>"
          min="<%= (validationRules.GetValidationRule('fat')).GetMinValue(); %>" 
          minLength="<%= (validationRules.GetValidationRule('fat')).GetMinLength(); %>"
          name="fat"
          <%= (validationRules.GetValidationRule('fat')).IsRequired(); %>          
          value="<%=recipeData.Recipe.Nutrition[0].$.fat %>"> g
  </span>
 </div> 
 
 <div class="recipe-line">
  <span class="field-header">
   Carbs:
  </span>
  <span class="field-value">
   <input data-validation="<%= (validationRules.GetValidationRule('carbs')).GetFieldTypeId(); %>" 
          id="carbs" 
          max="<%= (validationRules.GetValidationRule('carbs')).GetMaxValue(); %>" 
          maxLength="<%= (validationRules.GetValidationRule('carbs')).GetMaxLength(); %>"
          min="<%= (validationRules.GetValidationRule('carbs')).GetMinValue(); %>" 
          minLength="<%= (validationRules.GetValidationRule('carbs')).GetMinLength(); %>"
          name="carbs"
          <%= (validationRules.GetValidationRule('carbs')).IsRequired(); %>          
          value="<%=recipeData.Recipe.Nutrition[0].$.carbs %>"> g
  </span>
 </div>  
 
 <div class="recipe-line">
  <span class="field-header">
   Protein:
  </span>
  <span class="field-value">
   <input data-validation="<%= (validationRules.GetValidationRule('protein')).GetFieldTypeId(); %>" 
          id="protein" 
          max="<%= (validationRules.GetValidationRule('protein')).GetMaxValue(); %>" 
          maxLength="<%= (validationRules.GetValidationRule('protein')).GetMaxLength(); %>"
          min="<%= (validationRules.GetValidationRule('protein')).GetMinValue(); %>" 
          minLength="<%= (validationRules.GetValidationRule('protein')).GetMinLength(); %>"
          name="protein"
          <%= (validationRules.GetValidationRule('protein')).IsRequired(); %>          
          value="<%=recipeData.Recipe.Nutrition[0].$.protein %>"> g
  </span>
 </div>  
 
 <div class="recipe-line">
  <span class="field-header">
   Sugar:
  </span>
  <span class="field-value">
   <input data-validation="<%= (validationRules.GetValidationRule('sugar')).GetFieldTypeId(); %>" 
          id="sugar" 
          max="<%= (validationRules.GetValidationRule('sugar')).GetMaxValue(); %>" 
          maxLength="<%= (validationRules.GetValidationRule('sugar')).GetMaxLength(); %>"
          min="<%= (validationRules.GetValidationRule('sugar')).GetMinValue(); %>" 
          minLength="<%= (validationRules.GetValidationRule('sugar')).GetMinLength(); %>"
          name="sugar"
          <%= (validationRules.GetValidationRule('sugar')).IsRequired(); %>          
          value="<%=recipeData.Recipe.Nutrition[0].$.sugar %>"> g
  </span>
 </div> 
 
 <div class="recipe-line">
  <span class="field-header">
   Sodium:
  </span>
  <span class="field-value">
   <input data-validation="<%= (validationRules.GetValidationRule('sodium')).GetFieldTypeId(); %>" 
          id="sodium" 
          max="<%= (validationRules.GetValidationRule('sodium')).GetMaxValue(); %>" 
          maxLength="<%= (validationRules.GetValidationRule('sodium')).GetMaxLength(); %>"
          min="<%= (validationRules.GetValidationRule('sodium')).GetMinValue(); %>" 
          minLength="<%= (validationRules.GetValidationRule('sodium')).GetMinLength(); %>"
          name="sodium"
          <%= (validationRules.GetValidationRule('sodium')).IsRequired(); %>          
          value="<%=recipeData.Recipe.Nutrition[0].$.sodium %>"> mg
  </span>
 </div> 
 
 <div class="recipe-line">
  <span class="field-header">
   Fiber:
  </span>
  <span class="field-value">
   <input data-validation="<%= (validationRules.GetValidationRule('fiber')).GetFieldTypeId(); %>" 
          id="fiber" 
          max="<%= (validationRules.GetValidationRule('fiber')).GetMaxValue(); %>" 
          maxLength="<%= (validationRules.GetValidationRule('fiber')).GetMaxLength(); %>"
          min="<%= (validationRules.GetValidationRule('fiber')).GetMinValue(); %>" 
          minLength="<%= (validationRules.GetValidationRule('fiber')).GetMinLength(); %>"
          name="fiber"
          <%= (validationRules.GetValidationRule('fiber')).IsRequired(); %>          
          value="<%=recipeData.Recipe.Nutrition[0].$.fiber %>"> g
  </span>
 </div>  
 
 <br>
 
 <div class="recipe-line">
  <span class="field-header">
   <span style="display: inline-flex;  vertical-align: middle;">
    <img height="16px" 
         onclick='PopupBehaviors.RevealPopup("<%= enums.PopupTypes.Help %>");'
         onclick="ShowPopup('<%= enums.PopupTypes.Help %>');" 
         src="images/Buttons/HelpBtn_48X48.png" 
         title="Display editing help" 
         width="16px"> 
    &nbsp;  
    Description:
   </span>
  </span>
  <span class="field-value">
   <textarea cols="64" 
             data-validation="<%= (validationRules.GetValidationRule('description')).GetFieldTypeId(); %>" 
             id="description" 
             max="<%= (validationRules.GetValidationRule('description')).GetMaxValue(); %>" 
             maxLength="<%= (validationRules.GetValidationRule('description')).GetMaxLength(); %>"
             min="<%= (validationRules.GetValidationRule('description')).GetMinValue(); %>" 
             minLength="<%= (validationRules.GetValidationRule('description')).GetMinLength(); %>"
             name="description"
             placeholder="Provide a short description."
             <%= (validationRules.GetValidationRule('description')).IsRequired(); %>  
             rows="4"             
             type="text"><%= recipeData.Recipe.Description %></textarea>   
  </span>
 </div>  
 
 <div class="recipe-line">
  <br>
  <span class="field-header">
   Image:
  </span>
  <span class="field-value">
   <%
    var style = ("" == recipeData.Recipe.Title[0].$.image ? "display: none; visibility: collapse;" : "display: inline; visibility: visible;");
   %> 
   <img height="300px" 
        id="mainImage" 
        onclick='ViewImage("/images/Recipes/recipeData.Recipe.Title[0].$.image %>");' 
        src="/images/Recipes/<%= recipeData.Recipe.Title[0].$.image %>" 
        style="<%=style %>" 
        width="300px">
   <input id="mainImageName" 
          name="mainImageName" 
          readonly="readonly" 
          type="hidden" 
          value="<%=recipeData.Recipe.Title[0].$.image %>">
  </span>
 </div> 
 
 <div class="recipe-line">
  <span class="field-header">
   &nbsp;
  </span>
  <span class="field-value">
   <img height="24px"  
        onclick='PopupBehaviors.RevealPopup("<%= enums.PopupTypes.UploadFile %>", "", "mainImage");' 
        src="/images/Buttons/ChangeBtn_48X48.png" 
        title="Change Image" 
        width="24px">    
  </span>
 </div> 
 
 <br>
 
 <div class="table-container">
  <div class="heading">
   PREREQUISITES
  </div>
  <br>
  <div class="centered">
   <table align="center" class="scrolling-table" id="prerequisitesTable" width="500px">
    <thead>
     <tr>
      <th width="400px">
       Prerequisite
      </th>   
      <th colspan="2" width="55px">
       &nbsp;
      </th> 
     </tr>
    </thead>
    <tbody>
     <% 
      var ps = (true == (Object.getOwnPropertyNames(recipeData.Recipe.Prerequisites[0]).includes("Prerequisite")) ? 'display: inline; visibility: visible;' : 'display: none; visibility: collapse;');  
      if (Object.getOwnPropertyNames(recipeData.Recipe.Prerequisites[0]).includes("Prerequisite")) {
       var prerequisites = recipeData.Recipe.Prerequisites[0].Prerequisite;      
       for (ndx = 0; ndx < prerequisites.length; ++ndx) { 
     %> 
       <tr>
        <td style="max-width: 400px; min-width: 400px; word-wrap: break-word;">
         <%- commonUtils.RenderNewlines(prerequisites[ndx]); %>
         <input name="prerequisite" type="hidden" value="<%=prerequisites[ndx] %>">
        </td>
        <td colspan="2" style="max-width: 55px; min-width: 55px; text-align: right;">
         <span>
          <img height="24px" 
               onclick="DeletePrerequisite(<%=ndx %>);" 
               src="/images/Buttons/DeleteBtn_48X48.jpg" 
               title="Delete Prerequisite" 
               width="24px">  
          <img height="24px" 
               onclick="EditPrerequisite(<%=ndx %>);"   
               src="/images/Buttons/EditBtn_48X48.jpg"   
               title="Edit Prerequisite"   
               width="24px">       
         </span>         
        </td>
       </tr> 
     <%} }%>
    </tbody>
   </table>
  </div>
  <br>
  <div class="centered">
   <img height="48px" 
        id="<%= enums.ButtonTypes.AddPrerequisite %>"     
        onclick="ButtonBehaviors.HandleButtonClkd('<%= enums.ButtonTypes.AddPrerequisite %>');"     
        src="/images/Buttons/AddBtn_60X48_Dark.png"    
        style="margin: 0px 10px 0px 0px;" 
        title="<%= enums.GetDescFromButtonType(enums.ButtonTypes.AddPrerequisite); %>"         
        width="48px">   
   <img height="48px" 
        id="<%= enums.ButtonTypes.DeleteAllPrerequisites %>" 
        onclick="ButtonBehaviors.HandleButtonClkd('<%= enums.ButtonTypes.DeleteAllPrerequisites %>');" 
        src="/images/Buttons/DelAllBtn_48X48_Dark.png" 
        style="<%=ps %>"                  
        title="<%= enums.GetDescFromButtonType(enums.ButtonTypes.DeleteAllPrerequisites); %>" 
        width="48px">   
  </div> 
 </div> 
 
 <br>
 
 <div class="table-container">
  <div class="heading">
   INGREDIENTS
  </div>
  <br>
  <div class="centered">
  <table align="center" class="scrolling-table" id="ingredientsTable" width="940px">
   <thead>
    <tr>
     <th width="200px">
      Ingredient
     </th>
     <th width="70px">
      Quantity
     </th>
     <th width="80px">
      Measure
     </th>    
     <th width="130px">
      Preparation
     </th>  
     <th width="200px">
      Notes
     </th>   
     <th colspan="2" width="150px">
      &nbsp;
     </th>      
    </tr>
   </thead>
   <tbody>
    <% 
      var is = (true == (Object.getOwnPropertyNames(recipeData.Recipe.Ingredients[0]).includes("Ingredient")) ? 'display: inline; visibility: visible;' : 'display: none; visibility: collapse;');  
      
      if (Object.getOwnPropertyNames(recipeData.Recipe.Ingredients[0]).includes("Ingredient")) {    
       var ingredients = recipeData.Recipe.Ingredients[0].Ingredient;
       
       for (ndx = 0; ndx < ingredients.length; ++ndx) { 
        var type = "INGREDIENT";
        
        if ("undefined" != typeof(ingredients[ndx].$)) {
         type = ingredients[ndx].$.type;  
        }     

        if ("INGREDIENT" == type) {
         var prep  = enums.GetDescFromPrepType(ingredients[ndx].Prep[0]);
         var units = enums.GetDescFromUnitType(ingredients[ndx].Quantity[0].$.units);       
    %> 
      <tr>
       <td style="max-width: 200px; min-width: 200px; word-wrap: break-word;">
        <%- commonUtils.RenderNewlines(ingredients[ndx].Name[0]); %>
        <input name="ingredient"     type="hidden" value="<%=ingredients[ndx].Name[0] %>">
        <input name="ingredientType" type="hidden" value="INGREDIENT">
       </td>
       <td style="max-width: 70px;  min-width: 70px;  text-align: right; word-wrap: break-word;">
        <%=ingredients[ndx].Quantity[0]._ %>
        <input name="quantity" type="hidden" value="<%=ingredients[ndx].Quantity[0]._ %>">
       </td>
       <td style="max-width: 80px;  min-width: 80px;  word-wrap: break-word;">
        <%=units %>
        <input name="measure" type="hidden" value="<%=units %>">
       </td>
       <td style="max-width: 130px; min-width: 130px; word-wrap: break-word;">
        <%=prep %> 
        <input name="prep" type="hidden" value="<%=prep %>">        
       </td>
       <td style="max-width: 200px; min-width: 200px; word-wrap: break-word;">
        <%- commonUtils.RenderNewlines(ingredients[ndx].Notes[0]); %>
        <input name="notes" type="hidden" value="<%=ingredients[ndx].Notes[0] %>">        
       </td>
       <td colspan="2" style="max-width: 150px; min-width: 150px; text-align: right;">
        <img height="24px" 
             onclick="DeleteIngredient(<%=ndx %>);"   
             src="/images/Buttons/DeleteBtn_48X48.jpg" 
             title="Delete Ingredient"    
             width="24px">   
        <img height="24px" 
             onclick="EditIngredient(<%=ndx %>);"     
             src="/images/Buttons/EditBtn_48X48.jpg"   
             title="Edit Ingredient"      
             width="24px">        
        <img height="24px" 
             onclick="MoveIngredientUp(<%=ndx %>);"   
             src="/images/Buttons/UpBtn_48X48.png"     
             title="Move Ingredient Up"   
             width="24px">   
        <img height="24px" 
             onclick="MoveIngredientDown(<%=ndx %>);" 
             src="/images/Buttons/DownBtn_48X48.png"   
             title="Move Ingredient Down" 
             width="24px">                  
       </td>       
      </tr> 
     <% } else { %> 
      <tr>
       <td colspan="5" style="font-weight: bold; max-width: 500px; min-width: 500px; text-align: center; word-wrap: break-word;">
        <%- commonUtils.RenderNewlines(ingredients[ndx].Heading[0]); %> 
        <input name="ingredient"     type="hidden" value="<%=ingredients[ndx].Heading[0] %>">
        <input name="ingredientType" type="hidden" value="HEADING">
        <input name="quantity"       type="hidden" value="0">
        <input name="measure"        type="hidden" value="">
        <input name="prep"           type="hidden" value="">  
        <input name="notes"          type="hidden" value="">
       </td>
       <td colspan="2" style="max-width: 150px; min-width: 150px; text-align: right;">
        <img height="24px" 
             onclick="DeleteIngredient(<%=ndx %>);"   
             src="/images/Buttons/DeleteBtn_48X48.jpg" 
             title="Delete Ingredient"    
             width="24px">   
        <img height="24px" 
             onclick="EditIngredient(<%=ndx %>);"    
             src="/images/Buttons/EditBtn_48X48.jpg"   
             title="Edit Ingredient"      
             width="24px">        
        <img height="24px" 
             onclick="MoveIngredientUp(<%=ndx %>);"   
             src="/images/Buttons/UpBtn_48X48.png"     
             title="Move Ingredient Up"   
             width="24px">   
        <img height="24px" 
             onclick="MoveIngredientDown(<%=ndx %>);" 
             src="/images/Buttons/DownBtn_48X48.png"   
             title="Move Ingredient Down" 
             width="24px">            
       </td>        
      </tr>        
      <%}%>       
    <%} }%>  
   </tbody>
  </table>
  </div>
  <br>
  <div class="centered">
   <img height="48px"                           
        onclick="ButtonBehaviors.HandleButtonClkd('<%= enums.ButtonTypes.AddIngredient %>');"        
        src="/images/Buttons/AddBtn_60X48_Dark.png"                      
        title="<%= enums.GetDescFromButtonType(enums.ButtonTypes.AddIngredient); %>"         
        width="48px">
   <img height="48px"                           
        onclick="ButtonBehaviors.HandleButtonClkd('<%= enums.ButtonTypes.AddIngredientHeading %>');" 
        src="/images/Buttons/AddHdngBtn_60X48_Dark.png"                  
        title="<%= enums.GetDescFromButtonType(enums.ButtonTypes.AddIngredientHeading); %>" 
        width="48px">  
   <img height="48px" 
        id="<%= enums.ButtonTypes.DeleteAllIngredients %>" 
        onclick="ButtonBehaviors.HandleButtonClkd('<%= enums.ButtonTypes.DeleteAllIngredients %>');"    
        src="/images/Buttons/DelAllBtn_48X48_Dark.png"  
        style="<%=is %>" 
        title="<%= enums.GetDescFromButtonType(enums.ButtonTypes.DeleteAllIngredients); %>"
        width="48px">  
  </div> 
 </div>  
 
 <br> 
  
 <div class="table-container">
  <div class="heading">
   METHOD
  </div>
  <br> 
  <div class="centered">
   <table align="center" class="scrolling-table" id="stepsTable" width="720px">
    <thead>
     <tr>
      <th width="500px">
       Step
      </th>
      <th width="150px">
       Image
      </th>   
      <th colspan="2" width="150px">
       &nbsp;
      </th>       
     </tr>
    </thead>
    <tbody>
     <% 
      var ss = (true == (Object.getOwnPropertyNames(recipeData.Recipe.Method[0]).includes("Step")) ? 'display: inline; visibility: visible;' : 'display: none; visibility: collapse;');  
      
      if (Object.getOwnPropertyNames(recipeData.Recipe.Method[0]).includes("Step")) {
       var steps = recipeData.Recipe.Method[0].Step; 
       
       for(ndx = 0; ndx < steps.length; ++ndx) {
        var type = "STEP";
       
        if ("undefined" != typeof(steps[ndx].$)) {
         if ("undefined" != typeof(steps[ndx].$.type)) {
          type = steps[ndx].$.type;
         }
        }       
        
        var step = "";
        
        if (undefined != steps[ndx]._) {
         step = steps[ndx]._;
        } else {
         step = steps[ndx];
        }         
        
        if ("STEP" == type) {
         var imgSrc = "";
         
         if ("undefined" != typeof(steps[ndx].$)) {
          if ("undefined" != typeof(steps[ndx].$.image)) {
           if ("" != steps[ndx].$.image) {
            imgSrc = steps[ndx].$.image; 
           }
          }
         }
     %> 
        <tr>
         <td style="max-width: 400px; min-width: 400px; word-wrap: break-word;">
          <%- commonUtils.RenderNewlines(steps[ndx]._); %>
          <input name="step"     type="hidden" value="<%=step %>">
          <input name="stepType" type="hidden" value="STEP">
         </td>
         <% // *** DO NOT put the elements within the following td on separate lines or else images will not be editable. --> %>
         <td style="text-align: center; max-width: 100px; min-width: 100px; word-wrap: break-word;"><% 
          if ("" != imgSrc) { %><img height="32px" onclick='ViewImage("/images/Recipes/<%=imgSrc %>");' src="/images/Recipes/<%=imgSrc %>" width="32px"><input name="stepImage" type="hidden" value="<%=imgSrc %>"> <% } else { %><span>&nbsp;</span><input name="stepImage" type="hidden" value="<%=imgSrc %>"><%}%></td>         
         <td colspan="2" style="max-width: 150px; min-width: 150px; text-align: right;">
          <img height="24px" 
               onclick="DeleteStep(<%=ndx %>);"   
               src="/images/Buttons/DeleteBtn_48X48.jpg" 
               title="Delete Step"    
               width="24px">   
          <img height="24px" 
               onclick="EditStep(<%=ndx %>);"     
               src="/images/Buttons/EditBtn_48X48.jpg"   
               title="Edit Step"      
               width="24px">        
          <img height="24px" 
               onclick="MoveStepUp(<%=ndx %>);"   
               src="/images/Buttons/UpBtn_48X48.png"     
               title="Move Step Up"   
               width="24px">   
          <img height="24px" 
               onclick="MoveStepDown(<%=ndx %>);" 
               src="/images/Buttons/DownBtn_48X48.png"   
               title="Move Step Down" 
               width="24px">            
         </td>        
        </tr> 
     <% } else { %> 
      <tr>
       <td colspan="2" style="font-weight: bold; max-width: 250px; min-width: 250px; text-align: center; word-wrap: break-word;">
        <%- commonUtils.RenderNewlines(step); %> 
        <input name="step"      type="hidden" value="<%=step %>">
        <input name="stepType"  type="hidden" value="HEADING">
        <input name="stepImage" type="hidden" value="noimg.jpg">
