        id="mainImage" src="" 
        style="display: none; margin: 10px 0px 10px 0px; visibility: collapse;" 
        width="80px">
   <img height="48px" 
        onclick='PopupBehaviors.RevealPopup("<%= enums.PopupTypes.UploadFile %>", "", "mainImage");' 
        src="/images/Buttons/UploadBtn_48X48.png" 
        title="Upload" 
        width="48px"> 
  </span>
 </div>  
 
 <br>
 
 <div class="table-container">
  <div class="heading">
  </div>
