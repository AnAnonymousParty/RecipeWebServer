               minLength="<%= (validationRules.GetValidationRule('variation')).GetMinLength(); %>"
               name="variation2Edit"
               <%= (validationRules.GetValidationRule('variation')).IsRequired(); %>   
               placeholder="Enter new variation text."
               rows="4" 
               style="color: black; margin: 0px 0px 0px 3px; padding: 0px 0px 5px 0px;"               
               type="text"></textarea>
    </span>
   </div> 
  </div>
  <br> 
  <div class="centered">
   <img height="48px" 
        onclick="SaveVariation();" 
        src="/images/Buttons/SaveBtn_48X48.png" 
        title="Save" 
        width="48px">   
  </div>  
 </form>
</div>

