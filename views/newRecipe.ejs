<%# Conditionally displayed items for pop-ups, notifications, etc. %>

<%# Add Ingredient Popup. %>
<div class="popup" id="<%= enums.PopupTypes.AddIngredient %>" >
 <form>
  <input id="ingredientType" name="ingredientType" type="hidden" value="INGREDIENT">
  <div class="heading">
   <img height="24px" 
        onclick="PopupBehaviors.RevealPopup('<%= enums.PopupTypes.Help %>');" 
        src="images/Buttons/HelpBtn_48X48.png" 
        title="Display editing help" 
        width="24px"> 
   &nbsp;
   <%= enums.GetDescFromPopupType(enums.PopupTypes.AddIngredient); %>
   &nbsp;
   <img height="32px" 
        onclick="PopupBehaviors.HidePopup('<%= enums.PopupTypes.AddIngredient %>');"  
        src="/images/Buttons/CloseIcon_512X512.png" 
        width="32px">
  </div>
  <br>
  <div class="request-div" id="addIngredientForm">
   <div class="recipe-line">
    <span class="field-header">
     Ingredient:
    </span>
    <span class="field-value">
     <input data-validation="<%= (validationRules.GetValidationRule('ingredientName')).GetFieldTypeId(); %>" 
            id="ingredient2Add" 
            max="<%= (validationRules.GetValidationRule('ingredientName')).GetMaxValue(); %>" 
            maxLength="<%= (validationRules.GetValidationRule('ingredientName')).GetMaxLength(); %>"
            min="<%= (validationRules.GetValidationRule('ingredientName')).GetMinValue(); %>" 
            minLength="<%= (validationRules.GetValidationRule('ingredientName')).GetMinLength(); %>"
            name="ingredient2Add"
            <%= (validationRules.GetValidationRule('ingredientName')).IsRequired(); %>   
            placeholder="Enter ingredient name."
            type="text">
    </span>
   </div>
   <div class="recipe-line">
    <span class="field-header">
     Quantity:
    </span>
    <span class="field-value">
     <input data-validation="<%= (validationRules.GetValidationRule('quantity')).GetFieldTypeId(); %>" 
            id="quantity2Add" 
            max="<%= (validationRules.GetValidationRule('quantity')).GetMaxValue(); %>" 
            maxLength="<%= (validationRules.GetValidationRule('quantity')).GetMaxLength(); %>"
            min="<%= (validationRules.GetValidationRule('quantity')).GetMinValue(); %>" 
            minLength="<%= (validationRules.GetValidationRule('quantity')).GetMinLength(); %>"
            name="quantity2Add"
            <%= (validationRules.GetValidationRule('quantity')).IsRequired(); %>   
            type="number">
    </span>
   </div>  
   <div class="recipe-line">
    <span class="field-header">
     Measure:
    </span>
    <span class="field-value">
     <select id="measure2Add" name="measure2Add">
      <% Object.keys(enums.UnitTypes).forEach(function(key, index) { %><option value="<%=key %>"><%=this[key]%></option><% }, enums.UnitTypes); %>
     </select
    </span>
   </div>  
   <div class="recipe-line">
    <span class="field-header">
     Preparation:
    </span>
    <span class="field-value">
     <select id="preparation2Add" name="preparation2Add">
      <% Object.keys(enums.PreparationTypes).forEach(function(key, index) { %><option value="<%=key %>"><%=this[key]%></option><% }, enums.PreparationTypes); %>
     </select>
    </span>
   </div>   
   <div class="recipe-line">
    <span class="field-header">
     Notes:
    </span>
    <span class="field-value">
     <input data-validation="<%= (validationRules.GetValidationRule('notes')).GetFieldTypeId(); %>" 
            id="notes2Add" 
            max="<%= (validationRules.GetValidationRule('notes')).GetMaxValue(); %>" 
            maxLength="<%= (validationRules.GetValidationRule('notes')).GetMaxLength(); %>"
            min="<%= (validationRules.GetValidationRule('notes')).GetMinValue(); %>" 
            minLength="<%= (validationRules.GetValidationRule('notes')).GetMinLength(); %>"
            name="notes2Add"
            <%= (validationRules.GetValidationRule('notes')).IsRequired(); %>   
            placeholder="Enter notes."
            type="text">
    </span>
   </div>
  </div>
  <br>
  <div class="centered">
   <img height="48px" 
        onclick="AddIngredient();" 
        src="/images/Buttons/SaveBtn_48X48.png" 
        title="Save" width="48px">       
  </div>
 </form>
</div>

<%# Add Ingredient Heading Popup. %>
<div class="popup" id="<%= enums.PopupTypes.AddIngredientHeading %>">
 <form>
  <div class="heading">
   <img height="24px" 
