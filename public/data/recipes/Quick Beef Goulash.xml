<?xml version="1.0"?>
<Recipe>
  <Title image="Quick Beef Goulash_20260627_171744.jpg" name="Quick Beef Goulash" category="ENTREE_BEEF" cuisine="EASTEUROPE" nativeUnits="US">
    <Yield amount="8" units="SERVING"/>
    <Times prep="80" cook="30"/>
  </Title>
  <Nutrition calories="259" fat="10" saturatedFat="3" cholesterol="87" carbs="7" protein="34" sugar="3" sodium="548" fiber="1" servings="1" servingsUnit="CUP"/>
  <Description>Chunks of beef and potatoes in a sauce with tomato and paprika. This version uses skirt steak.</Description>
  <Prerequisites>
    <Prerequisite>Prepare @@Brown Beef Stock@@.</Prerequisite>
  </Prerequisites>
  <Ingredients>
    <Ingredient type="INGREDIENT">
      <Name>Skirt Steak</Name>
      <Quantity units="POUND">1</Quantity>
      <Prep>NONE</Prep>
      <Notes/>
    </Ingredient>
    <Ingredient type="INGREDIENT">
      <Name>Small potatoes</Name>
      <Quantity units="POUND">1</Quantity>
      <Prep>CLEANED</Prep>
      <Notes/>
    </Ingredient>
    <Ingredient type="INGREDIENT">
      <Name>Shallot</Name>
      <Quantity units="EACH">2</Quantity>
      <Prep>CHOPFINE</Prep>
      <Notes/>
    </Ingredient>
    <Ingredient type="INGREDIENT">
      <Name>Garlic</Name>
      <Quantity units="CLOVE">2</Quantity>
      <Prep>MINCED</Prep>
      <Notes/>
    </Ingredient>
    <Ingredient type="INGREDIENT">
      <Name>Parsley</Name>
      <Quantity units="TBSP">4</Quantity>
      <Prep>CHOPFINE</Prep>
      <Notes/>
    </Ingredient>
    <Ingredient type="INGREDIENT">
      <Name>@@Brown Beef Stock@@</Name>
      <Quantity units="CUP">4</Quantity>
      <Prep>NONE</Prep>
      <Notes/>
    </Ingredient>
    <Ingredient type="INGREDIENT">
      <Name>Tomato paste</Name>
      <Quantity units="CUP">.25</Quantity>
      <Prep>NONE</Prep>
      <Notes/>
    </Ingredient>
    <Ingredient type="INGREDIENT">
      <Name>Paprika</Name>
      <Quantity units="TBSP">2</Quantity>
      <Prep>NONE</Prep>
      <Notes>Hungarian Sweet</Notes>
    </Ingredient>
    <Ingredient type="INGREDIENT">
      <Name>Red Wine Vinegar</Name>
      <Quantity units="TBSP">2</Quantity>
      <Prep>NONE</Prep>
      <Notes/>
    </Ingredient>
    <Ingredient type="INGREDIENT">
      <Name>Caraway seeds</Name>
      <Quantity units="TSP">1</Quantity>
      <Prep>NONE</Prep>
      <Notes/>
    </Ingredient>
    <Ingredient type="INGREDIENT">
      <Name>Bacon Grease</Name>
      <Quantity units="TBSP">1</Quantity>
      <Prep>NONE</Prep>
      <Notes/>
    </Ingredient>
    <Ingredient type="INGREDIENT">
      <Name>Black Pepper</Name>
      <Quantity units="TSP">1</Quantity>
      <Prep>GROUND</Prep>
      <Notes/>
    </Ingredient>
    <Ingredient type="INGREDIENT">
      <Name>Kosher Salt</Name>
      <Quantity units="TSP">1</Quantity>
      <Prep>NONE</Prep>
      <Notes>To taste</Notes>
    </Ingredient>
    <Ingredient type="INGREDIENT">
      <Name>MSG</Name>
      <Quantity units="TSP">.25</Quantity>
      <Prep>NONE</Prep>
      <Notes/>
    </Ingredient>
    <Ingredient type="INGREDIENT">
      <Name>Worchestershire Sauce</Name>
      <Quantity units="TSP">1</Quantity>
      <Prep>NONE</Prep>
      <Notes/>
    </Ingredient>
  </Ingredients>
  <Method>
    <Step type="STEP" image="Quick%20Beef%20Goulash_20260627_142906.jpg">Cut steak against grain into 1/2 inch strips.</Step>
    <Step type="STEP" image="Quick%20Beef%20Goulash_20260627_143314.jpg">Marinate steak with Worchestershire sauce, salt, pepper and MSG for about an hour.</Step>
    <Step type="STEP" image="Quick%20Beef%20Goulash_20260627_155141.jpg">Heat bacon grease n a heavy skillet over high heat. Working in batches, sear steak.</Step>
    <Step type="STEP" image="Quick%20Beef%20Goulash_20260627_165946.jpg">Cut seared steak strips in to pieces and transfer to a bowl to hold.</Step>
    <Step type="STEP" image="Quick%20Beef%20Goulash_20260627_155606.jpg">Reduce heat, add shallots and cook until slightly browned.</Step>
    <Step type="STEP" image="Quick%20Beef%20Goulash_20260627_160617.jpg">Add beef stock, shallots, garlic, paprika, vinegar, and caraway seeds to a stock pot. </Step>
    <Step type="STEP" image="Quick%20Beef%20Goulash_20260627_161136.jpg">Add potatoes. Bring to a boil, then reduce to a simmer for 30 minutes.</Step>
    <Step type="STEP" image="Quick%20Beef%20Goulash_20260627_170323.jpg">Add steak and most of the parsley, and cook briefly until steak just done.</Step>
    <Step type="STEP" image="Quick%20Beef%20Goulash_20260627_171744.jpg">Serve, garnished with remaining parsley, with biscuits.</Step>
  </Method>
  <Variations>
    <Variation>Olive oil can be used instead of bacon grease.</Variation>
    <Variation>Smoked paprika can be used if you prefer.</Variation>
  </Variations>
</Recipe>