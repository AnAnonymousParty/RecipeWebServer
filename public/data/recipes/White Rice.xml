<?xml version="1.0"?>
<Recipe>
  <Title image="White Rice_WhiteRice.jpg" name="White Rice" category="SIDE" cuisine="ALL" nativeUnits="US">
    <Yield amount="4" units="CUP"/>
    <Times prep="1" cook="20"/>
  </Title>
  <Nutrition calories="" fat="" saturatedFat="" cholesterol="" carbs="" protein="" sugar="" sodium="" fiber="" servings=".5" servingsUnit="CUP"/>
  <Description>Plain white rice.

Rinsing the rice removes excess starch to help prevent foaming when cooking and sticking after cooking, The butter is extra insurance against foaming.</Description>
  <Prerequisites>
    <Prerequisite>Rinse rice until water runs clear.</Prerequisite>
  </Prerequisites>
  <Ingredients>
    <Ingredient type="INGREDIENT">
      <Name>White Rice</Name>
      <Quantity units="CUP">1.5</Quantity>
      <Prep>NONE</Prep>
      <Notes/>
    </Ingredient>
    <Ingredient type="INGREDIENT">
      <Name>&lt;a href='/GetRecipe?recipeName=Butter'&gt;Butter&lt;/a&gt;</Name>
      <Quantity units="TBSP">1</Quantity>
      <Prep>NONE</Prep>
      <Notes/>
    </Ingredient>
    <Ingredient type="INGREDIENT">
      <Name>Water</Name>
      <Quantity units="CUP">2</Quantity>
      <Prep>NONE</Prep>
      <Notes>Approximately.</Notes>
    </Ingredient>
    <Ingredient type="INGREDIENT">
      <Name>Kosher salt</Name>
      <Quantity units="TSP">1</Quantity>
      <Prep>NONE</Prep>
      <Notes/>
    </Ingredient>
  </Ingredients>
  <Method>
    <Step type="STEP" image="">Melt &lt;a href='/GetRecipe?recipeName=Butter'&gt;butter&lt;/a&gt; in a sauce pan.</Step>
    <Step type="STEP" image="">Add rinsed rice.</Step>
    <Step type="STEP" image="">Add water, until the rice is cover to the depth of the first joint of you index finger. IOW, when the tip of your finger is touching the rice, the water is at the first bend of your finger.</Step>
    <Step type="STEP" image="">Add salt.</Step>
    <Step type="STEP" image="">Cover, bring rice to a boil, reduce to a simmer until all water is absorbed.</Step>
  </Method>
  <Variations/>
</Recipe>