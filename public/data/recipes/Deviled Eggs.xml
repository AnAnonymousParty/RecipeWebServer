<?xml version="1.0"?>
<Recipe>
  <Title image="Deviled Eggs_20260420_090032.jpg" name="Deviled Eggs" category="APPETIZER" cuisine="AMERICAN" nativeUnits="US">
    <Yield amount="12" units="SERVING"/>
    <Times prep="30" cook="10"/>
  </Title>
  <Nutrition calories="60" fat="5" saturatedFat="2" cholesterol="103" carbs="0" protein="3.5" sugar=".2" sodium="130" fiber="0" servings="2" servingsUnit="ITEM"/>
  <Description>Boiled Eggs with creamy yolk filling.</Description>
  <Prerequisites>
    <Prerequisite>Prepare @@Mayonnaise@@. Or use Duke's.</Prerequisite>
  </Prerequisites>
  <Ingredients>
    <Ingredient type="INGREDIENT">
      <Name>Large Eggs</Name>
      <Quantity units="EACH">6</Quantity>
      <Prep>NONE</Prep>
      <Notes/>
    </Ingredient>
    <Ingredient type="INGREDIENT">
      <Name>@@Mayonnaise@@</Name>
      <Quantity units="TBSP">4</Quantity>
      <Prep>NONE</Prep>
      <Notes/>
    </Ingredient>
    <Ingredient type="INGREDIENT">
      <Name>Sweet Pickle Relish</Name>
      <Quantity units="TBSP">2</Quantity>
      <Prep>NONE</Prep>
      <Notes/>
    </Ingredient>
    <Ingredient type="INGREDIENT">
      <Name>Kosher Salt</Name>
      <Quantity units="TSP">1</Quantity>
      <Prep>NONE</Prep>
      <Notes>To taste</Notes>
    </Ingredient>
    <Ingredient type="INGREDIENT">
      <Name>White pepper</Name>
      <Quantity units="TSP">.5</Quantity>
      <Prep>NONE</Prep>
      <Notes>To taste</Notes>
    </Ingredient>
    <Ingredient type="INGREDIENT">
      <Name>Paprika</Name>
      <Quantity units="TSP">1</Quantity>
      <Prep>NONE</Prep>
      <Notes/>
    </Ingredient>
    <Ingredient type="INGREDIENT">
      <Name>MSG</Name>
      <Quantity units="TSP">.25</Quantity>
      <Prep>NONE</Prep>
      <Notes/>
    </Ingredient>
  </Ingredients>
  <Method>
    <Step type="STEP" image="Deviled%20Eggs_HardBoiledEggs.jpg">Make @@Hard Boiled Eggs@@.</Step>
    <Step type="STEP" image="Deviled%20Eggs_20260420_084116.jpg">Remove yolks to a bowl, mash together with mayonnaise, salt, pepper, and MSG. Fold in pickle relish.</Step>
    <Step type="STEP" image="">Spoon ##https://en.wikipedia.org/wiki/Quenelle|quenelles## of the yolk mixture into each egg.</Step>
    <Step type="STEP" image="Deviled%20Eggs_20260420_090032.jpg">Plate the eggs. Garnish with paprika. Chill and serve.</Step>
  </Method>
  <Variations>
    <Variation>Add a bit of cooked bacon to each egg.</Variation>
    <Variation>Top with a bit of caviar.</Variation>
  </Variations>
</Recipe>