<?xml version="1.0"?>
<Recipe>
  <Title image="Mexican Shredded Chicken_20260625_122437.jpg" name="Mexican Shredded Chicken" category="ENTREE_POULTRY" cuisine="MEXICAN" nativeUnits="US">
    <Yield amount="8" units="SERVING"/>
    <Times prep="10" cook="60"/>
  </Title>
  <Nutrition calories="184" fat="10" saturatedFat="2" cholesterol="108" carbs="1" protein="22" sugar="1" sodium="490" fiber="1" servings=".5" servingsUnit="CUP"/>
  <Description>Chicken thighs braised in spices and shredded. For @@Ultimate Nachos@@, tacos, enchiladas, burritos, etc.</Description>
  <Prerequisites>
    <Prerequisite>Prepare @@Chile Seasoning@@.</Prerequisite>
  </Prerequisites>
  <Ingredients>
    <Ingredient type="INGREDIENT">
      <Name>Chicken Breasts</Name>
      <Quantity units="EACH">4</Quantity>
      <Prep>NONE</Prep>
      <Notes/>
    </Ingredient>
    <Ingredient type="INGREDIENT">
      <Name>Yellow Onion</Name>
      <Quantity units="BULB">1</Quantity>
      <Prep>SLICED</Prep>
      <Notes/>
    </Ingredient>
    <Ingredient type="INGREDIENT">
      <Name>Jalepeno Pepper</Name>
      <Quantity units="EACH">1</Quantity>
      <Prep>SLICED</Prep>
      <Notes/>
    </Ingredient>
    <Ingredient type="INGREDIENT">
      <Name>Black Olive Juice</Name>
      <Quantity units="CUP">1</Quantity>
      <Prep>NONE</Prep>
      <Notes/>
    </Ingredient>
    <Ingredient type="INGREDIENT">
      <Name>@@Chile Seasoning@@</Name>
      <Quantity units="TBSP">4</Quantity>
      <Prep>NONE</Prep>
      <Notes/>
    </Ingredient>
    <Ingredient type="INGREDIENT">
      <Name>Bacon Grease or Olive Oil</Name>
      <Quantity units="TBSP">1</Quantity>
      <Prep>NONE</Prep>
      <Notes/>
    </Ingredient>
    <Ingredient type="INGREDIENT">
      <Name>Kosher Salt</Name>
      <Quantity units="TSP">0</Quantity>
      <Prep>NONE</Prep>
      <Notes>To taste</Notes>
    </Ingredient>
    <Ingredient type="INGREDIENT">
      <Name>Cilantro</Name>
      <Quantity units="SPRIG">12</Quantity>
      <Prep>CHOPFINE</Prep>
      <Notes/>
    </Ingredient>
    <Ingredient type="INGREDIENT">
      <Name>Garlic</Name>
      <Quantity units="CLOVE">2</Quantity>
      <Prep>CHOPFINE</Prep>
      <Notes/>
    </Ingredient>
  </Ingredients>
  <Method>
    <Step type="STEP" image="">Heat bacon grease/olive oil in a heavy skillet. Add Chicken thighs and sear on all sides.</Step>
    <Step type="STEP" image="Mexican%20Shredded%20Chicken_20260625_102150.jpg">Add onion and jalepeno, cook until softened.</Step>
    <Step type="STEP" image="Mexican%20Shredded%20Chicken_20260625_102332.jpg">Add black olive juice, garlic, chile seasoning and cilantro. </Step>
    <Step type="STEP" image="Mexican%20Shredded%20Chicken_20260625_121901.jpg">Bring to a boild, reduce to a simmer, cover and cook for one hour</Step>
    <Step type="STEP" image="Mexican%20Shredded%20Chicken_20260625_122437.jpg">Shred chicken with a pair of forks. Use or refrigerate until needed.</Step>
  </Method>
  <Variations/>
</Recipe>