<Recipe>
  <Title image="Chicken Goulash_20260108_171409.jpg" name="Chicken Goulash" category="STEW" cuisine="AMERICAN" nativeUnits="US">
    <Yield amount="6" units="SERVING"/>
    <Times prep="10" cook="60"/>
  </Title>
  <Nutrition calories="65" fat="1" saturatedFat=".3" cholesterol="14" carbs="8" protein="7" sugar=".5" sodium="220" fiber="2" servings="1" servingsUnit="CUP"/>
  <Description>Chunks of chicken and potato in a papriky broth.</Description>
  <Prerequisites/>
  <Ingredients>
